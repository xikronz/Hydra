#!/bin/bash
#SBATCH --job-name=hydra_pareto
#SBATCH --partition=gpu
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --gres=gpu:nvidia_rtx_a6000:1
#SBATCH --cpus-per-task=8
#SBATCH --mem=80G
#SBATCH --time=240:00:00
#SBATCH --output=/share/cuvl/cc2864/interpretable/Hydra/logs/pareto_%j.out
#SBATCH --error=/share/cuvl/cc2864/interpretable/Hydra/logs/pareto_%j.err

nvidia-smi
echo "CUDA_VISIBLE_DEVICES=$CUDA_VISIBLE_DEVICES"

set -x

mkdir -p logs

export HYDRA_REPO=/home/ubuntu/Hydra

python scripts/pareto_experiment.py \
  --hydra-checkpoint ankner/hydra-vicuna-7b-v1.3 \
  --base-model       lmsys/vicuna-7b-v1.3 \
  --sharegpt-path    data/sharegpt/raw/train.json \
  --calibration-prompts 300 \
  --max-new-tokens      256 \
  --max-input-tokens    1500 \
  --seed                42 \
  --temperature         0.7 \
  --posterior-threshold 0.09 \
  --posterior-alpha     0.3 \
  --out-json            logs/pareto_results.json
